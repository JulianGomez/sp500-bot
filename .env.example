# 🤖 Bot S&P 500 - Configuración
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# TELEGRAM (alertas en tu teléfono)
# ├─ TELEGRAM_TOKEN: @BotFather → /newbot → copiar token
# ├─ TELEGRAM_CHAT_ID: @userinfobot → copiar ID
# └─ Dejar vacío si no quieres usar Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# BINANCE TESTNET (opcional, para Crypto bot)
# ├─ https://testnet.binance.vision
# ├─ Generate HMAC_SHA256 Key
# └─ Copiar API Key y Secret
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# GITHUB (para persistencia de memory, opcional)
GIT_USER=
GIT_TOKEN=
GIT_REPO=

# ⚠️ IMPORTANTE: Este archivo NO se sube a GitHub (.gitignore tiene .env)
